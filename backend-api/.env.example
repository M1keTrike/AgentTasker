# Configuración de la aplicación
NODE_ENV=development
PORT=3000

# Configuración de PostgreSQL
# Desarrollo: DB_HOST=postgres (nombre del servicio en Docker)
# Producción: DB_HOST=ip-o-hostname-de-tu-base-de-datos
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change_me_in_production
DB_NAME=agentasker
DB_LOGGING=false

# Configuración de JWT
JWT_SECRET=change_me_with_a_strong_random_secret
JWT_EXPIRES_IN=1d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=